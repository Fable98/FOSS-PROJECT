# App
APP_NAME=SubTerra
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
API_VERSION=v1

# Database
POSTGRES_DB=subterra
POSTGRES_USER=subterra_user
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://subterra_user:replace-with-a-strong-password@db:5432/subterra

# Redis
REDIS_URL=redis://redis:6379
CACHE_EXPIRE_SECONDS=3600
CACHE_TTL_SEC=300

# Frontend / CORS
DOMAIN=example.com
REACT_APP_API_URL=
ALLOWED_ORIGINS=["https://example.com","https://www.example.com"]

# Data Sources
INDIA_WRIS_BASE_URL=https://indiawris.gov.in
WRIS_BASE_URL=https://indiawris.gov.in/wris
IMD_BASE_URL=https://imdaws.imd.gov.in
DATA_GOV_API_KEY=

# Scraper / Jobs
FETCH_INTERVAL_SEC=900
DATA_REFRESH_INTERVAL=21600
MAX_RETRIES=3
RETRY_BACKOFF_SEC=10
REQUEST_TIMEOUT_SEC=30

# Algorithm Defaults
TASK1_DEFAULT_HOURS=168
TASK2_DEFAULT_DAYS=365
TASK3_DEFAULT_DAYS=365
ALERT_LOOKBACK_HOURS=48
